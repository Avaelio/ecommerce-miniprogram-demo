/* 页面底层颜色 */
.my-container {
  min-height: 100vh;
  background-color: #f5f5f5; /* 浅灰底色，让卡片凸显 */
  padding-top: 20rpx;
}

/* 顶部卡片 */
.header-section {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 40rpx 30rpx;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
}

/* 🌟 清除头像 Button 的默认边框和背景 🌟 */
.avatar-btn {
  width: 120rpx !important;
  height: 120rpx !important;
  padding: 0 !important;
  margin: 0 !important;
  border-radius: 50%;
  background-color: transparent;
}
.avatar-btn::after { border: none; } /* 去掉微信默认黑边 */

.real-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.user-info {
  flex: 1;
  margin-left: 30rpx;
}

/* 🌟 清除文字登录 Button 的默认边框和背景 🌟 */
.login-action-btn {
  margin: 0 !important;
  padding: 0 !important;
  background-color: transparent !important;
  text-align: left;
  font-size: 36rpx;
  font-weight: bold;
  line-height: 1.2;
}
.login-action-btn::after { border: none; }

.nickname-input {
  font-size: 36rpx;
  font-weight: bold;
  height: 50rpx;
}

.desc {
  font-size: 24rpx;
  color: #888;
  margin-top: 10rpx;
}

.logout-btn {
  font-size: 24rpx;
  color: #666;
  border: 1px solid #ccc;
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
}

/* 资产卡片 */
.assets-card {
  display: flex;
  justify-content: space-around;
  background-color: #fff;
  padding: 30rpx 0;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
}
.asset-item { display: flex; flex-direction: column; align-items: center;}
.asset-value { font-size: 36rpx; font-weight: bold; color: #ff5722; margin-bottom: 10rpx;}
.asset-name { font-size: 24rpx; color: #666;}

/* 菜单列表卡片 */
.menu-list-card {
  background-color: #fff;
  margin: 0 20rpx;
  border-radius: 16rpx;
  padding: 0 30rpx;
}
.menu-item {
  display: flex;
  justify-content: space-between;
  padding: 30rpx 0;
  border-bottom: 1px solid #f0f0f0;
}
.menu-item:last-child { border-bottom: none; }