<view class="my-container">
  
  <!-- 1. 顶部用户信息区 -->
  <view class="header-section">
      <!-- 【未登录】：点击头像触发“获取手机号” -->
      <button wx:if="{{!isLogin}}" class="avatar-btn" open-type="getPhoneNumber" bindgetphonenumber="handleGetPhoneNumber">
        <image class="real-avatar" src="https://mmbiz.qpic.cn/mmbiz/icTdbqWNOwNRna42FI242Lcia07jQodd2FJGIYQfG0LAJGFxM4FbnQP6yfMxBgJ0F3YRqJCJ1aPAK2dQagdusBZg/0" mode="aspectFill"></image>
      </button>

      <!-- 【已登录】：点击头像触发“获取微信头像” -->
      <button wx:else class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image class="real-avatar" src="{{userInfo.avatarUrl || 'https://mmbiz.qpic.cn/mmbiz/icTdbqWNOwNRna42FI242Lcia07jQodd2FJGIYQfG0LAJGFxM4FbnQP6yfMxBgJ0F3YRqJCJ1aPAK2dQagdusBZg/0'}}" mode="aspectFill"></image>
      </button>
      
      <view class="user-info">
        <!-- 【未登录】：一键登录按钮 -->
        <button wx:if="{{!isLogin}}" class="login-action-btn" open-type="getPhoneNumber" bindgetphonenumber="handleGetPhoneNumber">手机号一键登录</button>
        
        <!-- 【已登录】：昵称输入框 -->
        <input wx:else type="nickname" class="nickname-input" value="{{userInfo.nickName}}" bindblur="onInputNickname" placeholder="点击设置昵称" />
        
        <view class="desc">{{isLogin ? '手机：' + userInfo.phoneNumber : '登录解锁会员特权'}}</view>
      </view>
      
      <view class="logout-btn" wx:if="{{isLogin}}" bindtap="handleLogout">退出</view>
  </view>

  <!-- 2. 资产展示区 -->
  <view class="assets-card">
    <view class="asset-item" wx:for="{{assets}}" wx:key="name">
      <view class="asset-value">{{item.value}}</view>
      <view class="asset-name">{{item.name}}</view>
    </view>
  </view>

  <!-- 3. 菜单列表区 -->
  <view class="menu-list-card">
    <view class="menu-item" wx:for="{{menuList}}" wx:key="name" bindtap="handleMenuClick" data-item="{{item}}">
      <text class="menu-name">{{item.name}}</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

</view>