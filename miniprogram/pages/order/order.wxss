/* 整个页面禁止自带的滚动，完全由代码控制内部滚动 */
page {
  height: 100vh;
  overflow: hidden;
  background-color: #F8F6F2;
}

.order-container {
  display: flex;
  flex-direction: column;
  height: 100%;
}

/* --- 核心分栏区域 --- */
.content-area {
  flex: 1; /* 撑满除了底部条之外的所有高度 */
  display: flex;
  overflow: hidden;
}

/* 左侧分类侧边栏 */
.sidebar {
  width: 180rpx;
  background-color: #F0ECE6;
  height: 100%;
}

.category-item {
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #666;
  position: relative;
}

.category-item.active {
  background-color: #F8F6F2; /* 和右侧背景融为一体 */
  color: #333;
  font-weight: bold;
}

/* 选中时的左侧标志性竖线 */
.category-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 30rpx;
  bottom: 30rpx;
  width: 8rpx;
  background-color: #A0887E; /* 品牌主题色 */
  border-radius: 0 4rpx 4rpx 0;
}

/* 右侧商品列表 */
.product-area {
  flex: 1;
  height: 100%;
  padding: 0 20rpx;
}

.category-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  padding: 30rpx 0 20rpx;
}

.product-card {
  display: flex;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.03);
}

.product-img-placeholder {
  width: 140rpx;
  height: 140rpx;
  background-color: #eee;
  border-radius: 12rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 24rpx;
  color: #aaa;
  margin-right: 20rpx;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.product-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.price-and-action {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10rpx;
}

.product-price {
  font-size: 32rpx;
  color: #E53935;
  font-weight: bold;
}

.add-btn {
  width: 48rpx;
  height: 48rpx;
  background-color: #A0887E;
  color: #fff;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 36rpx;
  font-weight: bold;
}

.bottom-space {
  height: 140rpx; /* 给底部悬浮条留出空间 */
}

/* --- 底部悬浮实时购物车 --- */
.bottom-cart-bar {
  position: absolute;
  bottom: 0; /* 如果是带 tabBar 的页面，这里可以保持 0，或者稍微悬浮 */
  left: 30rpx;
  right: 30rpx;
  bottom: 30rpx; /* 让它浮空，像个胶囊一样，更高级 */
  height: 100rpx;
  background-color: #333;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.2);
  z-index: 100;
  padding-left: 30rpx;
}

.cart-icon-wrapper {
  position: relative;
  margin-right: 20rpx;
}

.cart-icon {
  font-size: 60rpx;
}

.cart-badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  background-color: #E53935;
  color: #fff;
  font-size: 20rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-weight: bold;
  border: 4rpx solid #333;
}

.cart-price-info {
  flex: 1;
}

.total-price {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}

.checkout-btn {
  width: 180rpx;
  height: 100%;
  background-color: #555; /* 未激活状态的颜色 */
  color: #ccc;
  border-radius: 0 50rpx 50rpx 0;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 30rpx;
  font-weight: bold;
  transition: all 0.3s;
}

.checkout-btn.active {
  background-color: #A0887E; /* 有商品时亮起品牌色 */
  color: #fff;
}
/* --- 购物车明细弹窗与遮罩 --- */
.cart-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5); /* 半透明黑底 */
  z-index: 90; /* 盖住页面，但在弹窗之下 */
}

.cart-popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: -600rpx; /* 核心魔法：默认藏在屏幕最下面 */
  background-color: #fff;
  border-radius: 30rpx 30rpx 0 0;
  padding-bottom: 150rpx; /* 留出底部胶囊条的高度，防止挡住文字 */
  z-index: 95; /* 在遮罩之上，但在黑色胶囊条（100）之下 */
  transition: all 0.3s ease-in-out; /* 丝滑升起动画 */
}

.cart-popup.show {
  bottom: 0; /* 加上 show 样式后，立刻升到屏幕底部 */
}

.cart-popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background-color: #F8F6F2;
  border-radius: 30rpx 30rpx 0 0;
}

.cart-popup-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.cart-clear {
  font-size: 26rpx;
  color: #999;
}

.cart-popup-list {
  max-height: 450rpx; /* 最多显示几个，多了内部滑动 */
  padding: 0 30rpx;
}

.cart-popup-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 2rpx solid #eee;
  padding-right: 40rpx; /* Creates enough space for the button on the right */
  box-sizing: border-box; /* Ensures the padding is included in the element's total width calculation */
}

.cart-item-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.cart-item-price {
  font-size: 32rpx;
  color: #E53935;
  font-weight: bold;
  margin-right: 30rpx;
}

.cart-item-quantity {
  font-size: 28rpx;
  color: #A0887E;
  font-weight: bold;
}
/* --- 购物车商品加减控制器 --- */
.cart-item-stepper {
  display: flex;
  align-items: center;
  /* 加一点右边距，顺便解决你之前截图里右侧贴边太紧的问题 */
  margin-right: 20rpx; 
}

.step-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
  font-weight: bold;
}

.step-btn.minus {
  border: 2rpx solid #ccc;
  color: #666;
  background-color: #fff;
  box-sizing: border-box; /* 保证边框不撑大圆圈 */
}

.step-btn.plus {
  background-color: #A0887E; /* 品牌色 */
  color: #fff;
}

.step-num {
  margin: 0 24rpx;
  font-size: 30rpx;
  color: #333;
  min-width: 30rpx; /* 防止数字变两位数时乱晃 */
  text-align: center;
  font-weight: bold;
}